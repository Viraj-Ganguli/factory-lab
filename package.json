{
  "name": "factory-lab",
  "private": true,
  "version": "0.0.0",
  "description": "Throwaway 'club events' CRUD app used as a guinea pig for an autonomous coding-agent workflow.",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "migrate": "npm run migrate --prefix server",
    "migrate:down": "npm run migrate:down --prefix server",
    "seed": "npm run seed --prefix server",
    "test": "npm test --prefix server",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "supertest": "^7.0.0"
  }
}
