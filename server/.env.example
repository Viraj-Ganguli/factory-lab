# server/.env.example
#
# Copy to server/.env for local development. node-pg-migrate and the app
# both load this file automatically via dotenv. Never commit server/.env.

# Connection string used by the app, migrations, and seed script.
DATABASE_URL=postgres://factorylab:factorylab@localhost:5432/factorylab

# HTTP port for the Express API.
PORT=4000

# Used to sign the session cookie. Use a long random string in production.
SESSION_SECRET=change-me-in-a-real-deployment

NODE_ENV=development

# --- Seed data (server/seed/seed.js) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
