# Root .env.example
#
# This file documents the environment variables used across the project.
# Copy to `.env` (root) and/or `server/.env` and adjust as needed.
# `.env` files are gitignored; only `.env.example` files are committed.

# --- Database (used by docker-compose and server) ---
POSTGRES_USER=factorylab
POSTGRES_PASSWORD=factorylab
POSTGRES_DB=factorylab
DATABASE_URL=postgres://factorylab:factorylab@localhost:5432/factorylab

# --- Server ---
PORT=4000
SESSION_SECRET=change-me-in-a-real-deployment
NODE_ENV=development

# --- Seed data (used by server/seed/seed.js) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
